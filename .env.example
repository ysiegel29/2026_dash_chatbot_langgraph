# ── LLM providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# OSS model (vLLM / Ollama / any OpenAI-compatible endpoint)
OSS_BASE_URL=http://localhost:11434/v1
OSS_API_KEY=none

# ── Default model ─────────────────────────────────────────────────────────────
# provider: openai | anthropic | oss
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7

# ── MCP server ────────────────────────────────────────────────────────────────
MCP_URL=http://127.0.0.1:8765/mcp

# ── Persistence ───────────────────────────────────────────────────────────────
DB_PATH=data/checkpoints.db

# ── Services ──────────────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
GUI_PORT=8050

# ── Docker sandbox ────────────────────────────────────────────────────────────
SANDBOX_IMAGE=deepagent-sandbox:latest
SANDBOX_TIMEOUT=60

# ── Future S3 (not yet active) ────────────────────────────────────────────────
# S3_BUCKET=my-chatbot-bucket
# S3_PREFIX=threads/
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
