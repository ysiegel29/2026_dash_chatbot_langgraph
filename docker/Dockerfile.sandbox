# ── deepagent-sandbox ─────────────────────────────────────────────────────────
# Stateless execution environment for the LangGraph code-agent.
#
# Design principles:
#   - Non-root user 'sandbox' (uid 1000)
#   - No network access at runtime (enforced by docker run --network=none)
#   - Read-only root filesystem; /workspace and /tmp are tmpfs mounts
#   - Pre-installed scientific Python stack for fast cold starts
#
# Build:
#   docker build -f docker/Dockerfile.sandbox -t deepagent-sandbox:latest .
# ──────────────────────────────────────────────────────────────────────────────

FROM python:3.12-slim

# System deps (build tools needed only for packages with C extensions)
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential git curl \
    && rm -rf /var/lib/apt/lists/*

# Non-root user
RUN useradd -m -u 1000 -s /bin/bash sandbox

USER sandbox
WORKDIR /workspace

# Pre-install common scientific / data stack as the sandbox user
RUN pip install --no-cache-dir --user \
      numpy \
      pandas \
      matplotlib \
      seaborn \
      plotly \
      scikit-learn \
      scipy \
      statsmodels \
      pyarrow \
      duckdb \
      httpx \
      pydantic \
      tabulate \
      rich

ENV PATH="/home/sandbox/.local/bin:${PATH}" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    MPLBACKEND=Agg

# Default no-op; overridden by `docker run … <cmd>`
CMD ["python", "-c", "print('sandbox ready')"]
